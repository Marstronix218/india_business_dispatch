# LLM provider for multi-source article synthesis
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL_ANTHROPIC=claude-sonnet-4-6
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_MS=45000

# Clustering thresholds
CLUSTER_MIN_SHARED_KEYWORDS=3
CLUSTER_TIME_WINDOW_HOURS=48
CLUSTER_KEYWORDS_PER_ARTICLE=12

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron + Admin API auth
CRON_SECRET=
ADMIN_API_KEY=

# Optional (used by Python scraper and TS scraper fallback)
GNEWS_API_KEY=
GNEWS_QUERY=
GNEWS_LANG=en
GNEWS_COUNTRY=in

# Lead form email delivery
RESEND_API_KEY=
LEADS_TO_EMAIL=info@g-launchers.com
LEADS_FROM_EMAIL="India Business Dispatch <onboarding@resend.dev>"
