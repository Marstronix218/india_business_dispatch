# LLM provider for multi-source article synthesis
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL_ANTHROPIC=claude-sonnet-4-6
LLM_MODEL_OPENAI=gpt-5.4-mini
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_MS=45000

# Clustering thresholds
CLUSTER_MIN_SHARED_KEYWORDS=3
CLUSTER_TIME_WINDOW_HOURS=48
CLUSTER_KEYWORDS_PER_ARTICLE=12

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron + Admin API auth
CRON_SECRET=
ADMIN_API_KEY=

# Optional (used by Python scraper and TS scraper fallback)
GNEWS_API_KEY=
GNEWS_QUERY=
GNEWS_LANG=en
GNEWS_COUNTRY=in

# Stripe (paid membership)
# - For local dev: use sk_test_... and run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
#   (the CLI prints a whsec_... that goes into STRIPE_WEBHOOK_SECRET)
# - For prod: use sk_live_... and create a webhook endpoint in the Dashboard
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Image generation (replaces extracted images for copyright safety)
# IMAGE_PROVIDER: "openai" | "runware" | "none"
IMAGE_PROVIDER=openai
IMAGE_TIMEOUT_MS=90000

# OpenAI image generation (gpt-image-1-mini returns base64 → uploaded to Supabase Storage)
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=jpeg
OPENAI_IMAGE_COMPRESSION=75
SUPABASE_IMAGE_BUCKET=article-images

# Runware image generation (alternate provider)
RUNWARE_API_KEY=
RUNWARE_MODEL=runware:z-image@turbo
IMAGE_WIDTH=1280
IMAGE_HEIGHT=720
